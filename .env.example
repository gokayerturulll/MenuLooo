# Docker Compose bu dosyayı DEĞİL, kök dizindeki ".env" dosyasını okur.
# Bu dosya sadece bir şablon — projeyi ilk kez kuran biri bunu kopyalayıp
# kendi ".env" dosyasını oluşturur:
#
#   cp .env.example .env
#
# "db", "migrate" ve "backend" servisleri veritabanı kullanıcı adı/şifre
# konusunda burada TEK ve ORTAK bir kaynaktan besleniyor.
DB_NAME=menulo_db
DB_USER=menulo
DB_PASSWORD=menulo_secret

# backend container'ının çalışma modu: development | production
NODE_ENV=development
