# MenuLo Backend — Environment Variables (Template)
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── Server ──────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=menulo_db
DB_USER=
DB_PASSWORD=
DB_SSL=false

# ── JWT ─────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ── Socket.io ───────────────────────────────
SOCKET_CORS_ORIGIN=*

# ── iOS APNs (Push Notification) ────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.menulo.app

# ── AI Providers ────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=

# ── CORS ────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
